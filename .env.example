# Get this from https://aistudio.google.com -> "Get API key"
GEMINI_API_KEY=your_api_key_here

# Optional: override the Gemini model used by the backend (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: port for the Express server (Cloud Run sets this automatically)
# PORT=8787
